# === REQUERIDO ===
# API key de Groq (gratis en console.groq.com)
GROQ_API_KEY=gsk_xxxxxxxxxxxxxxxxxxxxxx

# === OPCIONAL: Google Maps API ===
# Necesitas activar: Geocoding API + Directions API en Google Cloud Console
# Se usa para sugerir calles alternativas cuando hay bloqueos/accidentes
# Sin esta key el bot funciona pero NO mostrará alternativas de ruta
GOOGLE_MAPS_API_KEY=

# === OPCIONAL: TomTom Traffic API ===
# Registro gratuito en developer.tomtom.com (2,500 req/día gratis)
# Si no se define, este monitor se deshabilita
TOMTOM_API_KEY=

# === OPCIONAL: Twitter/X ===
# Cuenta de sacrificio (burner account) para monitorear tweets
# Si no se define, este monitor se deshabilita
TWITTER_USER=
TWITTER_PASS=
TWITTER_EMAIL=

# === CONFIGURACIÓN ===
# Horas que un incidente permanece activo antes de expirar (default: 6)
INCIDENT_TTL_HOURS=6
